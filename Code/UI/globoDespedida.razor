@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

@if (IsVisible)
{
    <root class="stardew-container">
        <div class="stardew-dialogue-box" onclick=@(() => Close())>

            
            <div class="portrait-slot">
                @if (CurrentFish != null)
                {
                    <img src="@CurrentFish.IconPathChat" class="fish-portrait-img"/>
                }
                <div class="portrait-frame"></div>
            </div>

            <div class="dialogue-content">
				<h2 class="fish-name-label">@(CurrentFish?.Name ?? "Pez Desconocido")</h2>
				
				@if (DisplayMessage == "...")
				{
					<div class="loading-dots">
						<div class="dot"></div>
						<div class="dot"></div>
						<div class="dot"></div>
					</div>
				}
				else
				{
					<p class="message-text">@DisplayMessage</p>
				}
			</div>

            <!-- Actualizado el texto de ayuda -->
            <div class="continue-arrow">▼ (Presiona F para continuar)</div>
        </div>
    </root>
}

<style>
    /* El CSS se mantiene igual al anterior, es correcto */
    .stardew-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		display: flex;
		justify-content: center;
		align-items: flex-end;
		padding-bottom: 50px;
		z-index: 999;
		pointer-events: none; /* ✅ el contenedor NO bloquea el juego */
		background-color: transparent; /* ✅ sin fondo fantasma */
	}


    .stardew-dialogue-box {
		background-color: #f8d088;
		border: 4px solid #5d3a1a;
		width: 850px;   /* Antes 700px - Más ancho */
		height: 220px;  /* Antes 180px - Más alto */
		display: flex;
		padding: 25px;  /* Un poco más de aire interno */
		position: relative;
		box-shadow: 0 10px 0 #3a1f04;
		pointer-events: all;
	}

    .portrait-slot {
        width: 140px;
        height: 140px;
        background: #88c0f0;
        border: 4px solid #5d3a1a;
        flex-shrink: 0;
    }

    .fish-portrait-img {
        width: 100%;
        height: 100%;
        image-rendering: pixelated;
    }

    .dialogue-content {
		margin-left: 30px;
		flex-grow: 1;      /* Esto hace que el texto use todo el ancho disponible */
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		color: #3a1f04;
		font-family: 'Courier New', Courier, monospace;
		overflow: visible;
	}


    .fish-name-label {
        font-size: 28px; /* Un poco más grande para destacar */
        margin: 0 0 15px 0; /* Aumentamos el margen inferior para separar del mensaje */
        text-decoration: underline;
        font-weight: bold;
        flex-shrink: 0;
    }

    .message-text {
    font-size: 26px;
    /* Usa un multiplicador bajo (1.2 a 1.6) o píxeles fijos */
    
    margin: 0;
    
    width: 100%;
    white-space: normal;
    overflow: visible;    /* Permite que el texto respire */
    height: auto;
}

    .continue-arrow {
        position: absolute;
        bottom: 15px;
        right: 20px;
        animation: bounce 0.5s infinite alternate;
        color: #5d3a1a;
        font-family: sans-serif;
        font-size: 14px;
    }

	/* Contenedor de los puntos */
	.loading-dots {
		display: flex;
		gap: 8px;
		padding-top: 10px;
		align-items: center;
	}

	/* El punto individual */
	.dot {
		width: 12px;
		height: 12px;
		background-color: #3a1f04; /* Color del texto del pez */
		border-radius: 50%;
		animation: wave 1.2s infinite ease-in-out;
	}

	/* Retrasos para el efecto de ola */
	.dot:nth-child(2) { animation-delay: 0.2s; }
	.dot:nth-child(3) { animation-delay: 0.4s; }

	@@keyframes wave {
		0%, 60%, 100% { transform: translateY(0); }
		30% { transform: translateY(-15px); }
	}

    @@keyframes bounce {
        from { transform: translateY(0); }
        to { transform: translateY(5px); }
    }
</style>

@code {
    [Property] public bool IsVisible { get; set; } = false;
    [Property] public FishResource CurrentFish { get; set; }
    [Property] public string DisplayMessage { get; set; }

    public void ShowMessage(FishResource fish, string message)
    {
        CurrentFish = fish;
        DisplayMessage = message;
        IsVisible = true;
        Mouse.Visible = true; 
        StateHasChanged();
    }

	public void UpdateMessage(string message)
	{
		DisplayMessage = message;
		StateHasChanged();
	}


    protected override void OnUpdate()
    {
        if ( !IsVisible ) return;

        // detecta si se pulsa la f
        if ( Input.Pressed( "Interactuar" ) )
        {
            Close();
        }
    }

    public void Close()
    {
        Log.Info("Globo cerrado con éxito");
        IsVisible = false;
        Mouse.Visible = false; 
        CurrentFish = null;
        StateHasChanged();
    }
}

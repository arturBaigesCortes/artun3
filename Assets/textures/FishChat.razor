@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
    @if ( IsActive )
    {
        <div style="
            position: absolute;
            width: 70%;
            height: 92%;
            min-height: 350px;
            bottom: 50px;
            right: 50px;
            background-color: rgba(0, 5, 20, 0.98);
            border: 4px solid #51fcc0;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            pointer-events: all;
            box-shadow: 0 0 40px rgba(0,0,0,0.8);
        ">
            
                        <div style="
                background-color: #51fcc0;
                color: black;
                padding: 15px;
                font-weight: 900;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-top-left-radius: 15px;
                border-top-right-radius: 15px;
            ">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <img src="@FishThumb" style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid black;" />
                    <label style="font-size: 24px; text-transform: uppercase;">@FishDisplayName - Telepatía</label>
                </div>

                                <div style="
                    cursor: pointer;
                    padding: 0 20px;
                    background-color: #ff4444;
                    color: white;
                    border-radius: 8px;
                    font-size: 24px;
                " onclick=@CloseChat>
                    X
                </div>
            </div>

                        <div style="
                flex-grow: 1;
                padding: 30px;
                display: flex;
                flex-direction: column;
                gap: 20px; 
				overflow-y: scroll;


            "PreferScrollToBottom="true">
			<div style="flex-grow: 1;"></div>
                @foreach ( var msg in History )
                {
                    if ( msg.IsUser )
                    {
                            <div style="
							flex-shrink: 0;
                            align-self: flex-end;
                            background-color: #005c4b;
                            color: white;
                            padding: 15px 20px;
                            border-radius: 18px;
                            border-bottom-right-radius: 4px;
                            max-width: 80%;
                            font-size: 22px;
							margin-bottom: 5px;
                        ">
                            @msg.Text
                        </div>
                    }
                    else
                    {
                                                <div style="
							flex-shrink: 0;
                            align-self: flex-start;
                            display: flex;
                            gap: 12px;
                            max-width: 80%;
                        ">
                            <img src="@FishThumb" style="width: 35px; height: 35px; border-radius: 50%; border: 2px solid #51fcc0; flex-shrink: 0;" />
                            <div style="
                                background-color: #202c33;
                                color: white;
                                padding: 15px 20px;
                                border-radius: 18px;
                                border-bottom-left-radius: 4px;
                                border: 1px solid #51fcc033;
                                font-size: 22px;
                            ">
                                @msg.Text
                            </div>
                        </div>
                    }
                }
            </div>

                        <div style="
				flex-shrink: 0;
                padding: 25px;
                border-top: 2px solid #51fcc033;
                background-color: rgba(0,0,0,0.5);
                border-bottom-left-radius: 15px;
                border-bottom-right-radius: 15px;
            ">
                <Sandbox.UI.TextEntry 
                    @ref="InputBox"
                    Value:bind="@CurrentInput"
                    onsubmit="@SendMessage"
                    placeholder="Escribe tus pensamientos aquí..." 
                    style="
                        width: 100%;
                        height: 60px;
                        background-color: #0a0a0a;
                        color: #51fcc0;
                        caret-color: #51fcc0;
                        border: 1px solid #51fcc066;
                        padding: 0 20px;
                        font-size: 22px;
                        border-radius: 8px;
                    ">
                </Sandbox.UI.TextEntry>

                <label style="
                    font-size: 11px;
                    color: #555;
                    margin-top: 8px;
                    text-align: right;
                    width: 100%;
                ">
                    Presiona ENTER para enviar mensaje telepático
                </label>
            </div>
        </div>
    }
</root>

@code {
    [Property] public bool IsActive { get; set; } = false;
    [Property] public string FishThumb { get; set; } = "";
	[Property] public string FishDisplayName { get; set; } = "Pez"; // Nueva
	private FishResource ActiveFishResource; // Nueva para guardar el objeto
    
    string CurrentInput { get; set; } = "";
    TextEntry InputBox;

    public class ChatMessage
    {
        public string Text { get; set; }
        public bool IsUser { get; set; }
    }

    List<ChatMessage> History = new();

    public void Open( FishResource fishData ) 
	{
		if ( fishData == null ) return;

		// 1. Buscamos el cerebro en la escena para actualizarlo
		var brain = Scene.GetAllComponents<FishBrain>().FirstOrDefault();
		if ( brain != null )
		{
			// Forzamos al cerebro a cambiar de identidad y resetear memoria
			brain.CargarPez( fishData );
		}

		// 2. Actualizamos los datos visuales del chat
		ActiveFishResource = fishData; 
		FishThumb = fishData.IconPath;
		FishDisplayName = fishData.Name;
		IsActive = true;
		Mouse.Visible = true; 

		// 3. Resetear el historial visual del chat para el nuevo pez
		// Si no haces esto, verás los mensajes del pez anterior en la pantalla
		History.Clear(); 
		History.Add( new ChatMessage { Text = $"¿Qué quieres, humano? Soy un {fishData.Name}.", IsUser = false } );
		
		StateHasChanged();
	}
    void CloseChat() 
    {
        IsActive = false;
        CurrentInput = "";

		var decisionUI = Scene.GetAllComponents<chatFinalPez>().FirstOrDefault();
		if (decisionUI != null) 
		{
			decisionUI.Show(ActiveFishResource); // Método que crearemos ahora
		}
    }

    async void SendMessage()
    {
        if ( string.IsNullOrWhiteSpace( CurrentInput ) ) 
            return;

        var mensaje = CurrentInput.Trim();
        CurrentInput = "";

        // 1. Añadir mensaje del usuario a la lista
        History.Add( new ChatMessage { Text = mensaje, IsUser = true } );
        StateHasChanged();

        // 2. Buscar el componente FishBrain en la escena
        // Usamos Scene.GetAllComponents para que sea compatible con la versión actual
        var fishBrain = Scene.GetAllComponents<FishBrain>().FirstOrDefault();
        
        if ( fishBrain != null )
        {
            // 3. Llamar a la IA
			fishBrain.HasTalkedTo = true;
			fishBrain.Data = ActiveFishResource;
            string respuesta = await fishBrain.HablarConIA( mensaje );
            History.Add( new ChatMessage { Text = respuesta, IsUser = false } );
        }
        else
        {
            History.Add( new ChatMessage { Text = "Glub... no encuentro mi cerebro (Añade el componente FishBrain al pez)", IsUser = false } );
        }

        StateHasChanged();

		InputBox.Focus();

    }

	protected override void OnUpdate()
	{
		// Si el chat está abierto y tenemos la referencia de la caja...
		if ( IsActive && InputBox != null )
			{
				if ( !InputBox.HasFocus ) 
				{
					InputBox.Focus();
				}
			}
	}

	

    // El BuildHash ayuda a que la UI se refresque cuando cambia la lista de mensajes
    protected override int BuildHash() => System.HashCode.Combine( IsActive, FishThumb, CurrentInput, History.Count );
}
